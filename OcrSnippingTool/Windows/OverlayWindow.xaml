<Window x:Class="OcrSnippingTool.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="#55000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        KeyDown="OnKeyDown">

    <Canvas x:Name="SelectionCanvas">

        <!-- Instruction hint shown before selection starts -->
        <Border x:Name="HintBorder"
                Background="#CC1A1A2E"
                CornerRadius="6"
                Padding="12,6"
                Canvas.Left="20"
                Canvas.Top="20">
            <TextBlock Text="Drag to select a region    •    Esc to cancel"
                       Foreground="White"
                       FontSize="14"
                       FontFamily="Segoe UI"/>
        </Border>

        <!-- Rubber-band selection rectangle -->
        <Rectangle x:Name="SelectionRect"
                   Stroke="#FF00AAFF"
                   StrokeThickness="2"
                   Fill="#2200AAFF"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>

        <!-- Dimension label shown inside / near the selection -->
        <Border x:Name="DimBorder"
                Background="#CC1A1A2E"
                CornerRadius="4"
                Padding="6,2"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock x:Name="DimLabel"
                       Foreground="White"
                       FontSize="11"
                       FontFamily="Segoe UI"/>
        </Border>

    </Canvas>
</Window>
